generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  INVESTIGATOR
  ADMIN
}

enum UserCaseStatus {
  NOT_STARTED
  ACTIVE
  FINAL_REVIEW
  SOLVED
}

enum CaseWorkflowStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

enum TheoryResultLabel {
  CORRECT
  PARTIAL
  INCORRECT
}

enum SupportMessageStatus {
  NEW
  HANDLED
  SPAM
}

enum AccessCodeKind {
  BUREAU_REF
  ARTIFACT_QR
  WITNESS_TIP
  AUDIO_FILE
}

enum ActivationCodeSource {
  ADMIN
  PURCHASE
}

enum OrderStatus {
  PENDING
  COMPLETE
  FAILED
  REFUNDED
}

enum HiddenEvidenceKind {
  RECORD
  PERSON_DETAIL
  TIMELINE_EVENT
  HINT
  AUDIO
}

model User {
  id                     Int                 @id @default(autoincrement())
  email                  String              @unique
  name                   String?
  passwordHash           String
  role                   UserRole            @default(INVESTIGATOR)
  createdAt              DateTime            @default(now())
  ownedCases             UserCase[]
  claimedActivationCodes ActivationCode[]    @relation("ClaimedCodes")
  theorySubmissions      TheorySubmission[]
  checkpointAttempts     CheckpointAttempt[]
  caseAudits             CaseAudit[]
  accessCodeRedemptions  AccessCodeRedemption[]
}

model CaseFile {
  id                  Int                 @id @default(autoincrement())
  slug                String              @unique
  title               String
  summary             String
  players             String
  duration            String
  difficulty          String
  maxStage            Int                 @default(3)
  solutionSuspect     String              @default("")
  solutionMotive      String              @default("")
  solutionEvidence    String              @default("")
  debriefOverview     String              @default("")
  debriefWhatHappened String              @default("")
  debriefWhyItWorked  String              @default("")
  debriefClosing      String              @default("")
  debriefSectionTitle String?
  debriefIntro        String?
  heroImageUrl        String?
  workflowStatus      CaseWorkflowStatus  @default(DRAFT)
  publishedAt         DateTime?
  isActive            Boolean             @default(true)
  createdAt           DateTime            @default(now())
  activationCodes     ActivationCode[]
  owners              UserCase[]
  people              CasePerson[]
  records             CaseRecord[]
  hints               CaseHint[]
  checkpoints         CaseCheckpoint[]
  theorySubmissions   TheorySubmission[]
  checkpointAttempts  CheckpointAttempt[]
  audits              CaseAudit[]
  slugHistory         CaseSlugHistory[]
  accessCodes         AccessCode[]           @relation("CaseAccessCodes")
  redemptions         AccessCodeRedemption[] @relation("CaseRedemptions")
  hiddenEvidence      HiddenEvidence[]       @relation("CaseHiddenEvidence")
  orders              Order[]
}

model CaseSlugHistory {
  id         Int      @id @default(autoincrement())
  caseFileId Int
  oldSlug    String   @unique
  createdAt  DateTime @default(now())

  caseFile CaseFile @relation(fields: [caseFileId], references: [id], onDelete: Cascade)
}

model CaseAudit {
  id         Int      @id @default(autoincrement())
  caseFileId Int
  userId     Int
  action     String
  diff       Json
  createdAt  DateTime @default(now())

  caseFile CaseFile @relation(fields: [caseFileId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])
}

model ActivationCode {
  id              Int                  @id @default(autoincrement())
  code            String               @unique
  kitSerial       String?
  source          ActivationCodeSource @default(ADMIN)
  caseFileId      Int
  claimedByUserId Int?
  claimedAt       DateTime?
  revokedAt       DateTime?
  createdAt       DateTime             @default(now())

  caseFile      CaseFile @relation(fields: [caseFileId], references: [id], onDelete: Cascade)
  claimedByUser User?    @relation("ClaimedCodes", fields: [claimedByUserId], references: [id])
  order         Order?
}

model UserCase {
  id            Int       @id @default(autoincrement())
  userId        Int
  caseFileId    Int
  currentStage  Int       @default(1)
  status        UserCaseStatus @default(ACTIVE)
  activatedAt   DateTime  @default(now())
  firstOpenedAt DateTime?
  lastViewedAt  DateTime?
  completedAt   DateTime?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  caseFile CaseFile @relation(fields: [caseFileId], references: [id], onDelete: Cascade)
  events   UserCaseEvent[]

  @@unique([userId, caseFileId])
}

model UserCaseEvent {
  id         Int      @id @default(autoincrement())
  userCaseId Int
  type       String
  payload    Json
  createdAt  DateTime @default(now())

  userCase UserCase @relation(fields: [userCaseId], references: [id], onDelete: Cascade)
}

model CasePerson {
  id             Int      @id @default(autoincrement())
  caseFileId     Int
  globalPersonId Int?
  name           String
  role           String
  summary        String
  portraitUrl    String?
  unlockStage    Int      @default(1)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  caseFile     CaseFile      @relation(fields: [caseFileId], references: [id], onDelete: Cascade)
  globalPerson GlobalPerson? @relation(fields: [globalPersonId], references: [id])
}

model CaseRecord {
  id          Int      @id @default(autoincrement())
  caseFileId  Int
  title       String
  category    String
  summary     String
  body        String
  unlockStage Int      @default(1)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  caseFile CaseFile @relation(fields: [caseFileId], references: [id], onDelete: Cascade)
}

model CaseHint {
  id          Int      @id @default(autoincrement())
  caseFileId  Int
  level       Int
  title       String
  content     String
  unlockStage Int      @default(1)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  caseFile CaseFile @relation(fields: [caseFileId], references: [id], onDelete: Cascade)
}

model CaseCheckpoint {
  id              Int      @id @default(autoincrement())
  caseFileId      Int
  stage           Int
  prompt          String
  acceptedAnswers String
  successMessage  String
  createdAt       DateTime @default(now())

  caseFile CaseFile @relation(fields: [caseFileId], references: [id], onDelete: Cascade)

  @@unique([caseFileId, stage])
}

model CheckpointAttempt {
  id         Int      @id @default(autoincrement())
  userId     Int
  caseFileId Int
  stage      Int
  answer     String
  isCorrect  Boolean
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  caseFile CaseFile @relation(fields: [caseFileId], references: [id], onDelete: Cascade)
}

model TheorySubmission {
  id              Int      @id @default(autoincrement())
  userId          Int
  caseFileId      Int
  suspectName     String
  motive          String
  evidenceSummary String
  suspectCorrect  Boolean  @default(false)
  motiveCorrect   Boolean  @default(false)
  evidenceCorrect Boolean  @default(false)
  score           Int      @default(0)
  resultLabel     TheoryResultLabel
  feedback        String   @default("")
  createdAt       DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  caseFile CaseFile @relation(fields: [caseFileId], references: [id], onDelete: Cascade)
}

model WaitlistEntry {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
}

model SupportMessage {
  id        Int                  @id @default(autoincrement())
  name      String
  email     String
  message   String
  status    SupportMessageStatus @default(NEW)
  createdAt DateTime             @default(now())
}

model GlobalPerson {
  id                Int      @id @default(autoincrement())
  bureauId          String   @unique
  firstName         String
  lastName          String
  fullName          String
  dateOfBirth       String?
  knownLocation     String?
  status            String   @default("UNKNOWN")
  personType        String   @default("PERSON_OF_INTEREST")
  classification    String   @default("STANDARD")
  riskLevel         String   @default("LOW")
  relevanceLevel    String   @default("UNASSESSED")
  profileSummary    String   @default("")
  internalNotes     String   @default("")
  lastUpdatedLabel  String   @default("Recently reviewed")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  gender            String?
  accessLevel       String   @default("STANDARD")
  sourceReliability String   @default("UNVERIFIED")
  confidenceLevel   String   @default("MEDIUM")
  watchlistFlag     String   @default("NONE")

  behavioralProfile PersonBehavioralProfile?
  digitalTraces     PersonDigitalTrace[]
  timelineEvents    PersonTimelineEvent[]
  evidenceLinks     PersonEvidenceLink[]
  analystNotes      PersonAnalystNote[]

  aliases           PersonAlias[]
  caseAppearances   CasePerson[]
  sourceConnections PersonConnection[] @relation("SourcePersonConnections")
  targetConnections PersonConnection[] @relation("TargetPersonConnections")
}

model PersonAlias {
  id             Int      @id @default(autoincrement())
  globalPersonId Int
  alias          String
  aliasType      String   @default("KNOWN_ALIAS")
  createdAt      DateTime @default(now())

  globalPerson GlobalPerson @relation(fields: [globalPersonId], references: [id], onDelete: Cascade)

  @@unique([globalPersonId, alias])
}

model PersonConnection {
  id             Int      @id @default(autoincrement())
  sourcePersonId Int
  targetPersonId Int
  connectionType String
  summary        String   @default("")
  visibility     String   @default("STANDARD")
  createdAt      DateTime @default(now())

  sourcePerson GlobalPerson @relation("SourcePersonConnections", fields: [sourcePersonId], references: [id], onDelete: Cascade)
  targetPerson GlobalPerson @relation("TargetPersonConnections", fields: [targetPersonId], references: [id], onDelete: Cascade)
}

model PersonBehavioralProfile {
  id                   Int      @id @default(autoincrement())
  globalPersonId       Int      @unique
  behavioralRead       String   @default("")
  observedPatterns     String   @default("")
  stressIndicators     String   @default("")
  communicationStyle   String   @default("")
  socialBehavior       String   @default("")
  conflictHistory      String   @default("")
  motiveThreads        String   @default("")
  escalationIndicators String   @default("")
  analystAssessment    String   @default("")
  analystConfidence    String   @default("UNASSESSED")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  globalPerson GlobalPerson @relation(fields: [globalPersonId], references: [id], onDelete: Cascade)
}

model PersonDigitalTrace {
  id             Int      @id @default(autoincrement())
  globalPersonId Int
  category       String
  label          String
  value          String
  confidence     String   @default("UNASSESSED")
  notes          String   @default("")
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  globalPerson GlobalPerson @relation(fields: [globalPersonId], references: [id], onDelete: Cascade)
}

model PersonTimelineEvent {
  id              Int      @id @default(autoincrement())
  globalPersonId  Int
  dateLabel       String
  category        String
  title           String
  summary         String
  confidence      String   @default("UNASSESSED")
  relatedCaseSlug String?
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())

  globalPerson GlobalPerson @relation(fields: [globalPersonId], references: [id], onDelete: Cascade)
}

model PersonEvidenceLink {
  id               Int      @id @default(autoincrement())
  globalPersonId   Int
  evidenceType     String
  title            String
  summary          String
  confidence       String   @default("UNASSESSED")
  relatedCaseSlug  String?
  relatedCaseTitle String?
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())

  globalPerson GlobalPerson @relation(fields: [globalPersonId], references: [id], onDelete: Cascade)
}

model PersonAnalystNote {
  id             Int      @id @default(autoincrement())
  globalPersonId Int
  category       String
  title          String
  content        String
  severity       String   @default("INFO")
  visibility     String   @default("INTERNAL")
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  globalPerson GlobalPerson @relation(fields: [globalPersonId], references: [id], onDelete: Cascade)
}

model AccessCode {
  id             Int       @id @default(autoincrement())
  code           String    @unique
  kind           AccessCodeKind
  caseFileId     Int
  caseFile       CaseFile  @relation("CaseAccessCodes", fields: [caseFileId], references: [id], onDelete: Cascade)
  unlocksTarget  Json
  requiresStage  Int?
  oneTimePerUser Boolean   @default(false)
  retiredAt      DateTime?
  createdAt      DateTime  @default(now())
  redemptions    AccessCodeRedemption[]
}

model AccessCodeRedemption {
  id           Int        @id @default(autoincrement())
  accessCodeId Int
  userId       Int
  caseFileId   Int
  redeemedAt   DateTime   @default(now())
  accessCode   AccessCode @relation(fields: [accessCodeId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  caseFile     CaseFile   @relation("CaseRedemptions", fields: [caseFileId], references: [id], onDelete: Cascade)

  @@unique([accessCodeId, userId])
}

model HiddenEvidence {
  id          Int                @id @default(autoincrement())
  caseFileId  Int
  caseFile    CaseFile           @relation("CaseHiddenEvidence", fields: [caseFileId], references: [id], onDelete: Cascade)
  title       String
  kind        HiddenEvidenceKind
  body        String
  revealOrder Int
  createdAt   DateTime           @default(now())
}

model Order {
  id                  Int             @id @default(autoincrement())
  stripeSessionId     String          @unique
  stripePaymentIntent String?
  status              OrderStatus     @default(PENDING)
  email               String
  caseFileId          Int
  caseFile            CaseFile        @relation(fields: [caseFileId], references: [id])
  activationCodeId    Int?            @unique
  activationCode      ActivationCode? @relation(fields: [activationCodeId], references: [id])
  emailSentAt         DateTime?
  emailLastError      String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
}
