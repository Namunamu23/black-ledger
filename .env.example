# Database (Prisma + PostgreSQL)
#
# For Neon:
#   DATABASE_URL  = the pooled connection string (Neon Dashboard → Connection Details → Pooled connection)
#   DIRECT_URL    = the direct (non-pooled) connection string (used by prisma migrate only)
#
# For Supabase:
#   DATABASE_URL  = Session-mode pooler URL  (port 5432, Transaction mode if preferred)
#   DIRECT_URL    = Direct connection URL     (port 5432, no pooler)
#
# For Railway:
#   DATABASE_URL  = the PostgreSQL connection URL from the Railway dashboard
#   DIRECT_URL    = same value as DATABASE_URL (Railway does not use a separate pooler)
#
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# NextAuth — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('base64url'))"
AUTH_SECRET=

# Initial admin seeded by `npm run seed:admin` (scripts/create-admin.ts)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Upstash Redis credentials for production rate limiting (lib/rate-limit.ts).
# Leave both blank to use the in-memory dev backend. Both must be set for
# the Upstash backend to activate.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Required in production — set to your deployed URL (e.g. https://blackledger.app).
# Used by middleware.ts to enforce CSRF on state-mutating /api/* requests.
# Falls back to http://localhost:3000 when unset (dev only).
NEXT_PUBLIC_APP_URL=

# Cloudflare R2 (S3-compatible) for image uploads.
# All five must be set for the upload pipeline (lib/uploads + image admin
# tabs) to work; otherwise /api/admin/uploads/sign returns 503.
#
#   R2_ACCOUNT_ID         the Cloudflare account id that owns the bucket
#   R2_ACCESS_KEY_ID      access key id from R2 → Manage API Tokens
#   R2_SECRET_ACCESS_KEY  matching secret access key
#   R2_BUCKET_NAME        the bucket that stores uploads/{hero,portrait,record}/...
#   R2_PUBLIC_URL         public base URL for the bucket (e.g. https://pub-xxx.r2.dev)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Stripe — required for /api/checkout and /api/webhooks/stripe.
#   STRIPE_SECRET_KEY     server-side secret key (sk_test_... or sk_live_...)
#   STRIPE_WEBHOOK_SECRET signing secret from `stripe listen` or the dashboard
#                         webhook endpoint (whsec_...)
#   STRIPE_PRICE_ID       Stripe Price ID for the kit line item (price_...)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
